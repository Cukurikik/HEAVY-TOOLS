generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════════
// Core User Model (Assuming NextAuth integration)
// ═══════════════════════════════════════════════════
model User {
  id            String             @id @default(cuid())
  email         String             @unique
  name          String?
  role          String             @default("USER")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // Video Engine Relations
  videoTasks    VideoTaskHistory[]
  videoPresets  VideoPreset[]
  watermarks    WatermarkTemplate[]
  cloudVideos   CloudVideo[]

  // Audio Engine Relations
  audioTasks      AudioTaskHistory[]
  audioPresets    AudioPreset[]
  masteringChains MasteringChain[]
  cloudAudios     CloudAudio[]
}

// ═══════════════════════════════════════════════════
// FASE 2: Video Engine Schemas
// ═══════════════════════════════════════════════════

// 11. Schema VideoTaskHistory
model VideoTaskHistory {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolName       String    // e.g., "Video Trimmer", "Merger"
  inputFile      String?   
  outputFile     String?
  durationSeconds Int?
  status         String    @default("success") // success, error
  errorMessage   String?
  createdAt      DateTime  @default(now())

  // 19. Index Optimization Video
  @@index([createdAt])
  @@index([userId])
}

// 12. Schema VideoPreset
model VideoPreset {
  id             String    @id @default(uuid())
  userId         String?   // Global presets can have null userId
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    // e.g., "Export YouTube 4K"
  tool           String
  settings       Json      // Store options like { crf: 18, resolution: "3840x2160" }
  isGlobal       Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// 13. Schema WatermarkTemplate
model WatermarkTemplate {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  type           String    // "text" or "image"
  content        String    // Text content or Image URL
  position       String    // e.g., "bottom-right"
  opacity        Float     @default(1.0)
  scale          Float     @default(1.0)
  createdAt      DateTime  @default(now())
}

// 14. Schema CloudVideo
model CloudVideo {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String
  sizeBytes      BigInt
  mimeType       String
  isPinned       Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// 15. Schema VideoAnalytics (Anonymous Telemetry)
model VideoAnalytics {
  id             String    @id @default(uuid())
  sessionId      String?   // Anonymous session ID
  toolName       String
  processTimeMs  Int
  inputFormat    String?
  outputFormat   String?
  success        Boolean   @default(true)
  errorMessage   String?
  createdAt      DateTime  @default(now())
}

// 20. Audit Log Video Deletion table
model AuditLog {
  id             String    @id @default(uuid())
  tableName      String
  recordId       String
  action         String    @default("DELETE")
  userId         String?
  details        Json?
  createdAt      DateTime  @default(now())
}

// ═══════════════════════════════════════════════════
// FASE 2 (AUDIO): Audio Engine Schemas
// ═══════════════════════════════════════════════════

// 11. Schema AudioTaskHistory
model AudioTaskHistory {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  toolName       String    // e.g., "Stem Splitter", "Mastering Hub"
  inputFile      String?   
  outputFile     String?
  durationMs     Int?
  status         String    @default("success") // success, error
  errorMessage   String?
  createdAt      DateTime  @default(now())

  // 19. Index Optimization Audio
  @@index([createdAt])
  @@index([userId])
}

// 12. Schema AudioPreset
model AudioPreset {
  id             String    @id @default(uuid())
  userId         String?   // Global presets can have null userId
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    // e.g., "Podcast Enhancer Default"
  tool           String
  settings       Json      // Store parameter options
  isGlobal       Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// 13. Schema MasteringChain
model MasteringChain {
  id             String    @id @default(uuid())
  userId         String?   // allow null for global/default chains
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String    // e.g., "Vocal Pop Chain"
  chain          Json      // Array sequence of fx: [{type: 'eq'}, {type: 'compressor'}]
  isGlobal       Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// 14. Schema CloudAudio
model CloudAudio {
  id             String    @id @default(uuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName       String
  fileUrl        String
  sizeBytes      BigInt
  mimeType       String
  isPinned       Boolean   @default(false)
  createdAt      DateTime  @default(now())
}

// 15. Schema AudioAnalytics (Anonymous Telemetry)
model AudioAnalytics {
  id             String    @id @default(uuid())
  sessionId      String?   // Anonymous session ID
  toolName       String
  processTimeMs  Int
  inputFormat    String?
  outputFormat   String?
  success        Boolean   @default(true)
  errorMessage   String?
  createdAt      DateTime  @default(now())
}

